# Telegram configuration
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# RSS feed URL (default is Basque Country coordinates)
RSS_URL=https://in-the-sky.org/rss.php?feed=dfan&latitude=43.139006&longitude=-2.966625&timezone=Europe/Madrid

# Observer location
LATITUDE=43.139006
LONGITUDE=-2.966625
TIMEZONE=Europe/Madrid

# Fetch interval (minutes)
FETCH_INTERVAL_MINUTES=60

# Notification window (days)
NOTIFICATION_WINDOW_DAYS=15

# Database path
DB_PATH=data/events.db
