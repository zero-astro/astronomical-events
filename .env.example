# Telegram configuration
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# RSS feed URL (default is Basque Country coordinates)
RSS_URL=https://in-the-sky.org/rss.php?feed=dfan&latitude=43.139006&longitude=-2.966625&timezone=Europe/Madrid

# Observer location
LATITUDE=43.139006
LONGITUDE=-2.966625
TIMEZONE=Europe/Madrid

# Fetch interval (minutes)
FETCH_INTERVAL_MINUTES=60

# Notification window (days)
NOTIFICATION_WINDOW_DAYS=15

# Database path
DB_PATH=data/events.db

# === i18n / Translation Configuration ===
TRANSLATION_ENABLED=true
TRANSLATION_PROVIDER=lm-studio          # lm-studio | ollama | openai
TRANSLATION_LM_STUDIO_API_BASE=http://localhost:1234/v1
TRANSLATION_OLLAMA_API_BASE=http://localhost:11434/v1
TRANSLATION_OPENAI_API_BASE=https://api.openai.com/v1
TRANSLATION_MODEL=qwen3.6-35b-a3b       # LM Studio model name
OPENAI_API_KEY=your_openai_key_here     # Only needed for openai provider
TARGET_LANGUAGES=eu,ca                  # Comma-separated: eu, ca, gl, es, fr
